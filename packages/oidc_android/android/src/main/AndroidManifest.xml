<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
      Android 11+ (API 30) package visibility: without this, the plugin (and the
      OS) cannot resolve browsers / Chrome Custom Tabs providers to launch the
      auth URL, and any browser-selection / warmup logic would silently fail.
      Mirrors AppAuth-Android's library manifest. See
      https://developer.android.com/training/package-visibility
    -->
    <queries>
        <!-- Browsers able to handle an https auth URL. -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
        <!-- Custom Tabs service providers (capability detection / warmup). -->
        <intent>
            <action android:name="androidx.browser.customtabs.action.CustomTabsService" />
        </intent>
    </queries>
    <application>
        <!--
          Plugin-owned redirect receiver. The consuming app drives the scheme
          with a single manifest placeholder in its app/build.gradle:

              manifestPlaceholders += ['oidcRedirectScheme': 'com.example.app']

          A safe default is provided in this library's build.gradle so apps that
          pull oidc transitively but do not use the native redirect flow still
          build. Apps doing mobile login MUST override it with their own
          redirect_uri scheme.
        -->
        <activity
            android:name="com.bdayadev.oidc.OidcRedirectActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="${oidcRedirectScheme}" />
            </intent-filter>
        </activity>
    </application>
</manifest>
